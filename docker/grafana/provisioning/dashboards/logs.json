      "options": { "content": "# 微服务日志中心\n实时查看和搜索各服务日志", "mode": "markdown" },
      "type": "text"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 2 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (service) (count_over_time({job=~\"$service\"} [$__interval]))", "legendFormat": "{{service}}", "refId": "A" }],
      "title": "日志量趋势（按服务）",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } },
