# Education Platform - Docker Environment Variables
# Copy this file to .env before running docker compose.
# All credentials below are examples only. Replace them for real deployments.

# MySQL Configuration
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-me-mysql-root-password
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me-mysql-app-password
MYSQL_DATABASE_USER=edu_user
MYSQL_DATABASE_COURSE=edu_course

# Redis Configuration
REDIS_PORT=6379
REDIS_PASSWORD=

# Nacos Configuration
NACOS_PORT=8848
NACOS_GRPC_PORT=9848
NACOS_SERVER_ADDR=nacos:8848
NACOS_AUTH_TOKEN=change-me-nacos-token
NACOS_AUTH_IDENTITY_KEY=serverIdentity
NACOS_AUTH_IDENTITY_VALUE=security

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASS=change-me-rabbitmq-password
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672

# Elasticsearch Configuration
ES_PORT=9200
ELASTICSEARCH_URIS=http://elasticsearch:9200

# Zipkin Configuration
ZIPKIN_PORT=9411

# Application Configuration
JWT_SECRET=change-me-with-a-minimum-32-character-jwt-secret
INTERNAL_SERVICE_TOKEN=change-me-internal-service-token
WEB_APP_ORIGIN=http://localhost:3000
WEB_APP_VITE_ORIGIN=http://localhost:5173
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
